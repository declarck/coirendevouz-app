# Kopyalayın: copy .env.example .env  (Windows: copy .env.example .env)
# Gizli değerleri asla commit etmeyin.

# Django
DJANGO_SECRET_KEY=change-me-in-development-use-long-random-string
DJANGO_DEBUG=true
# Virgülle ayrılmış hostlar
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Tarayıcıdan frontend (Vite) — CORS; virgülle ayrı origin
# DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8001,http://127.0.0.1:8001

# Veritabanı — PostgreSQL (önerilen)
# Seçenek A: tek satır bağlantı
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Seçenek B: ayrı alanlar
POSTGRES_DB=coirendevouz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=buraya-postgres-parolaniz
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

